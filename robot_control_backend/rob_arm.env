# ====================== 硬件转换参数 ======================
ENC_TO_DEG=0.01248
DEG_PER_TICK=0.01248
DEGREE_PER_TICK=0.01248
TELES_MM_PER_REV=0.7
MM_PER_REV=0.7
PRESSURE_MAX_ADC=16777215
PRESSURE_MAX_KG=10.0

# ====================== 编码器限位 ======================
ENC_MID=15000
ENC_MIN=580
ENC_MAX=29420

# ====================== 伸缩轴长度限制 ======================
MIN_LENGTH=0.0
MAX_LENGTH=150.0

# ====================== 模块与设备 ID ======================
MODULE_ID=17
TARGET_MODULE_ID=17
DEV_ROTATE=41
DEV_SWING=42
DEV_TELES=43
DEV_SENSOR=49
DEV_ROTATE_CONTROL=33
DEV_SWING_CONTROL=34
DEV_TELES_CONTROL=35

# ====================== 串口配置 ======================
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200

# ====================== ROS 话题名称 ======================
ROS_TOPIC_ALL_FEEDBACK=/hardware/all_feedback
ROS_TOPIC_ROTATION_OUTPUT=/hardware/rotation_output
ROS_TOPIC_SWING_OUTPUT=/hardware/swing_output
ROS_TOPIC_TELESCOPE_OUTPUT=/hardware/telescope_output
ROS_TOPIC_ARM_CMD_VEL=/arm/cmd_vel
ROS_TOPIC_ROTATION_FEEDBACK=/hardware/rotation_feedback
ROS_TOPIC_SWING_FEEDBACK=/hardware/swing_feedback
ROS_TOPIC_TELESCOPE_FEEDBACK=/hardware/telescope_feedback
ROS_TOPIC_SENSOR_FEEDBACK=/hardware/sensor_feedback
ROS_TOPIC_MODULE_CMD=/hardware/module_cmd
ROS_TOPIC_KINEMATICS_POSE=/control/kinematics_pose
ROS_TOPIC_KINEMATICS_ROTATION_CMD=/control/kinematics_rotation_cmd
ROS_TOPIC_KINEMATICS_SWING_CMD=/control/kinematics_swing_cmd
ROS_TOPIC_KINEMATICS_TELESCOPIC_CMD=/control/kinematics_telescopic_cmd
ROS_TOPIC_MODULE_CONFIRM_SUCCESS=/control/module_confirm_success
ROS_TOPIC_ADJUST_ROTATION_CMD=/control/adjust_rotation_cmd
ROS_TOPIC_ADJUST_SWING_CMD=/control/adjust_swing_cmd
ROS_TOPIC_ADJUST_TELESCOPIC_CMD=/control/adjust_telescopic_cmd
ROS_TOPIC_SENSOR_CMD=/control/sensor_cmd